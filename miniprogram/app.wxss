/* 全局样式 */
page {
  background: linear-gradient(145deg, #0f0f1a 0%, #1a1a2e 50%, #0f0f1a 100%);
  min-height: 100vh;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
  color: #f0f0f0;
}

.container {
  padding: 24rpx;
  padding-bottom: 180rpx;
}

/* Hero 区域 */
.hero-card {
  background: linear-gradient(135deg, rgba(255, 107, 107, 0.15) 0%, rgba(255, 142, 83, 0.1) 100%);
  border-radius: 24rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 32rpx;
  border: 1px solid rgba(255, 107, 107, 0.2);
}

.hero-title {
  font-size: 56rpx;
  font-weight: 700;
  background: linear-gradient(135deg, #ff6b6b 0%, #ffa94d 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 16rpx;
}

.hero-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  line-height: 1.6;
}

/* 区块标题 */
.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-title::before {
  content: '';
  width: 6rpx;
  height: 32rpx;
  background: linear-gradient(180deg, #ff6b6b, #ffa94d);
  border-radius: 3rpx;
}

/* 快速决定面板 */
.action-panel {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 32rpx;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.action-row {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.select-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.select-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.picker-selector {
  background: rgba(255, 107, 107, 0.2);
  color: #ff6b6b;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.primary-btn {
  background: linear-gradient(135deg, #ff6b6b 0%, #ffa94d 100%);
  color: white;
  font-size: 30rpx;
  font-weight: 600;
  padding: 28rpx;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}

.primary-btn::after {
  border: none;
}

/* 生成的菜单列表 */
.generated-list {
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.option-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.05);
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
}

.option-item strong {
  font-size: 28rpx;
  font-weight: 500;
}

/* BB 精选 */
.hot-section {
  margin-bottom: 32rpx;
}

.hot-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.hot-chip {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 107, 107, 0.1);
  border: 1px solid rgba(255, 107, 107, 0.2);
  padding: 16rpx 20rpx;
  border-radius: 100rpx;
}

.hot-chip strong {
  font-size: 26rpx;
  font-weight: 500;
}

/* 挑菜区 */
.browse-section {
  margin-bottom: 32rpx;
}

.category-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 24rpx;
  overflow-x: auto;
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.tab-btn {
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.6);
  font-size: 26rpx;
  padding: 16rpx 28rpx;
  border-radius: 100rpx;
  border: none;
  flex-shrink: 0;
}

.tab-btn::after {
  border: none;
}

.tab-btn.active {
  background: linear-gradient(135deg, #ff6b6b 0%, #ffa94d 100%);
  color: white;
}

.dish-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.dish-card {
  background: rgba(255, 255, 255, 0.03);
  border-radius: 16rpx;
  overflow: hidden;
  border: 1px solid rgba(255, 255, 255, 0.06);
}

.dish-image {
  height: 140rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  background: rgba(255, 255, 255, 0.02);
}

.dish-body {
  padding: 16rpx 20rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dish-body h3 {
  font-size: 26rpx;
  font-weight: 500;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 添加按钮 */
.add-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 107, 107, 0.15);
  color: #ff6b6b;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 1;
}

.add-btn::after {
  border: none;
}

.add-btn.selected {
  background: #ff6b6b;
  color: white;
}

/* 底部栏 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(180deg, transparent 0%, #0f0f1a 30%);
}

.bar-primary {
  display: flex;
  align-items: center;
  gap: 20rpx;
  background: linear-gradient(135deg, #ff6b6b 0%, #ffa94d 100%);
  padding: 24rpx 32rpx;
  border-radius: 100rpx;
  width: 100%;
  box-sizing: border-box;
  border: none;
}

.bar-primary::after {
  border: none;
}

.fab-badge {
  background: white;
  color: #ff6b6b;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bar-copy {
  flex: 1;
  text-align: left;
}

.bar-copy strong {
  display: block;
  color: white;
  font-size: 30rpx;
  font-weight: 600;
}

.bar-copy small {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

/* 抽屉遮罩 */
.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 100;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.drawer-mask.show {
  opacity: 1;
  visibility: visible;
}

/* 抽屉面板 */
.drawer-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #1a1a2e;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease-out;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
}

.drawer-panel.show {
  transform: translateY(0);
}

.drawer-handle {
  width: 64rpx;
  height: 8rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 4rpx;
  margin: 20rpx auto;
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 32rpx 24rpx;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.drawer-tag {
  font-size: 22rpx;
  color: #ff6b6b;
  text-transform: uppercase;
  letter-spacing: 2rpx;
  margin-bottom: 8rpx;
}

.drawer-header h2 {
  font-size: 36rpx;
  font-weight: 600;
}

.drawer-close {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.05);
  color: rgba(255, 255, 255, 0.6);
  font-size: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.drawer-close::after {
  border: none;
}

.drawer-summary {
  padding: 24rpx 32rpx;
  color: rgba(255, 255, 255, 0.6);
  font-size: 26rpx;
}

.selected-list {
  padding: 0 32rpx;
  padding-bottom: calc(32rpx + env(safe-area-inset-bottom));
  flex: 1;
  overflow-y: auto;
}

.selected-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.selected-item:last-child {
  border-bottom: none;
}

.selected-item strong {
  font-size: 30rpx;
  font-weight: 500;
  margin-bottom: 4rpx;
  display: block;
}

.selected-item p {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.5);
}

.remove-btn {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  background: rgba(255, 107, 107, 0.15);
  color: #ff6b6b;
  font-size: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.remove-btn::after {
  border: none;
}

/* Toast */
.toast {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%) scale(0.9);
  background: rgba(0, 0, 0, 0.8);
  color: white;
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  z-index: 200;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, transform 0.3s, visibility 0.3s;
}

.toast.show {
  opacity: 1;
  visibility: visible;
  transform: translate(-50%, -50%) scale(1);
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 48rpx 0;
  color: rgba(255, 255, 255, 0.5);
}

.empty-state strong {
  display: block;
  font-size: 30rpx;
  margin-bottom: 8rpx;
  color: rgba(255, 255, 255, 0.7);
}

.empty-state p {
  font-size: 26rpx;
}
